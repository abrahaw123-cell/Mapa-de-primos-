/* Tooltip */
.tooltip {
position: fixed;
background: #0d0d0d;
border: 1px solid var(–orange);
color: var(–orange);
font-size: 0.6rem;
padding: 4px 8px;
border-radius: 3px;
pointer-events: none;
display: none;
z-index: 100;
font-family: ‘Share Tech Mono’, monospace;
line-height: 1.5;
}
